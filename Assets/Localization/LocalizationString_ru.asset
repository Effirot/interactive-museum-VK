  - m_Id: 6709156466688
    m_Localized: "\u0412\u0441\u0451 \u0440\u0430\u0432\u043D\u043E, \u0441\u043F\u0430\u0441\u0438\u0431\u043E
      \u0432\u0430\u043C \u0437\u0430 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044E.
      \u0414\u0443\u043C\u0430\u044E, \u0432\u0441\u0451 \u0436\u0435 \u043F\u043E\u0435\u0434\u0443
      \u0442\u0443\u0434\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 6729792442368
    m_Localized: "\u041D\u0435 \u0442\u0435\u0440\u044F\u0439\u0442\u0435 \u043D\u0430\u0434\u0435\u0436\u0434\u044B.
      \u0415\u0441\u043B\u0438 \u0410\u0440\u0442\u0451\u043C \u043F\u0440\u043E\u043F\u0430\u043B,
      \u0442\u043E, \u0432\u0438\u0434\u0438\u043C\u043E, \u0432\u0441\u0451 \u0436\u0435
      \u043D\u0430\u0448\u0451\u043B \u043D\u0443\u0436\u043D\u044B\u0435 \u0435\u043C\u0443
      \u043F\u043E\u0434\u0441\u043A\u0430\u0437\u043A\u0438. \u0410 \u0440\u0430\u0437
      \u0442\u0430\u043A, \u0442\u043E \u0438\u0445 \u0441\u043C\u043E\u0436\u0435\u0442\u0435
      \u043D\u0430\u0439\u0442\u0438 \u0438 \u0432\u044B. \u0410 \u0442\u0430\u043C
      \u043E\u0442\u044B\u0449\u0438\u0442\u0435 \u0438 \u0435\u0433\u043E \u0441\u0430\u043C\u043E\u0433\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 6740324339712
    m_Localized: "\u041D\u0430\u0448\u0435 \u043F\u0435\u0440\u0432\u043E\u0435 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435
      \u0431\u044B\u043B\u043E \u043D\u0435\u0434\u0430\u043B\u0451\u043A\u0438\u043C,
      \u043D\u043E \u0441\u0430\u043C\u044B\u043C \u0432\u043E\u043B\u043D\u0443\u044E\u0449\u0438\u043C\u2026
      \u0410\u0440\u0442\u0451\u043C, \u044F \u0441\u043A\u0443\u0447\u0430\u044E."
    m_Metadata:
