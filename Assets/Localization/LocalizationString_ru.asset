  m_TableData:
  - m_Id: 225391628288
    m_Localized: "\u0410\u043D\u0433\u043B\u0438\u0439\u0441\u043A\u0438\u0439"
    m_Metadata:
      m_Items: []
  - m_Id: 4182943944704
    m_Localized: "\u0418\u0433\u0440\u0430\u0442\u044C"
    m_Metadata:
      m_Items: []
  - m_Id: 4355547942912
    m_Localized: "\u041D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0438"
    m_Metadata:
      m_Items: []
  - m_Id: 4517745872896
    m_Localized: "\u0412\u044B\u0445\u043E\u0434"
    m_Metadata:
      m_Items: []
  - m_Id: 4564088737792
    m_Localized: "\u041D\u0430\u0437\u0430\u0434"
    m_Metadata:
      m_Items: []
  - m_Id: 4605696233472
    m_Localized: "\u0421\u0447\u0435\u0442\u0447\u0438\u043A FPS"
    m_Metadata:
      m_Items: []
  - m_Id: 4662000570368
    m_Localized: "\u042F\u0437\u044B\u043A"
    m_Metadata:
      m_Items: []
  - m_Id: 4842825404416
    m_Localized: "\u0420\u0443\u0441\u0441\u043A\u0438\u0439"
    m_Metadata:
      m_Items: []
  - m_Id: 4923620282368
    m_Localized: "\u0413\u0440\u0430\u0444\u0438\u043A\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 5038644875264
    m_Localized: "\u0417\u0432\u0443\u043A"
    m_Metadata:
      m_Items: []
  - m_Id: 5071930871808
    m_Localized: "\u041C\u0443\u0437\u044B\u043A\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 5104378007552
    m_Localized: "\u041A\u043E\u043D\u0441\u044C\u0435\u0440\u0436"
    m_Metadata:
      m_Items: []
  - m_Id: 5174473216000
    m_Localized: "\u0410\u043D\u043D\u0430"
    m_Metadata:
      m_Items: []
  - m_Id: 5208799399936
    m_Localized: "\u0410\u0440\u0442\u0435\u043C"
    m_Metadata:
      m_Items: []
  - m_Id: 5236414697472
    m_Localized: "\u042D\u0440\u0438\u0445"
    m_Metadata:
      m_Items: []
  - m_Id: 5270308868096
    m_Localized: "\u0414\u043E\u0431\u0440\u043E\u0435 \u0443\u0442\u0440\u043E.
      \u041F\u0440\u043E\u0441\u0442\u0438\u0442\u0435 \u0437\u0430 \u043D\u0435\u043E\u0436\u0438\u0434\u0430\u043D\u043D\u044B\u0439
      \u0432\u0438\u0437\u0438\u0442."
    m_Metadata:
      m_Items: []
  - m_Id: 5386574974976
    m_Localized: "\u0412\u0441\u0451 \u0432 \u043F\u043E\u0440\u044F\u0434\u043A\u0435.
      \u0410 \u0447\u0442\u043E-\u0442\u043E \u0441\u043B\u0443\u0447\u0438\u043B\u043E\u0441\u044C?"
    m_Metadata:
      m_Items: []
  - m_Id: 5393181003776
    m_Localized: "\u0421\u0435\u0433\u043E\u0434\u043D\u044F \u0440\u0430\u043D\u043E
      \u0443\u0442\u0440\u043E\u043C \u043A \u0432\u0430\u043C \u0437\u0430\u0445\u043E\u0434\u0438\u043B
      \u0443\u0447\u0430\u0441\u0442\u043A\u043E\u0432\u044B\u0439. \u0421\u043A\u0430\u0437\u0430\u043B,
      \u0447\u0442\u043E \u0434\u043B\u044F \u0432\u0430\u0441 \u0435\u0441\u0442\u044C
      \u0432\u0430\u0436\u043D\u0430\u044F \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044F.
      \u041E\u043D \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0441\u0432\u044F\u0437\u0430\u0442\u044C\u0441\u044F
      \u0441 \u0432\u0430\u043C\u0438, \u043D\u043E \u0442\u0430\u043A \u0438 \u043D\u0435
      \u0441\u043C\u043E\u0433 \u0434\u043E\u0437\u0432\u043E\u043D\u0438\u0442\u044C\u0441\u044F.
      \u0410 \u043F\u043E\u0442\u043E\u043C \u0435\u0433\u043E \u043A\u0443\u0434\u0430-\u0442\u043E
      \u0432\u044B\u0437\u0432\u0430\u043B\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 5506565623808
    m_Localized: "\u041E\u043D \u043F\u0440\u043E\u0441\u0438\u043B \u043F\u0435\u0440\u0435\u0434\u0430\u0442\u044C
      \u0432\u0430\u043C \u044D\u0442\u043E\u0442 \u0444\u043B\u0435\u0448-\u043A\u043E\u0434.
      \u042D\u0442\u043E \u0434\u0430\u0441\u0442 \u0432\u0430\u043C \u0434\u043E\u0441\u0442\u0443\u043F
      \u043A \u0434\u0430\u043D\u043D\u044B\u043C, \u0447\u0442\u043E \u043E\u043D\u0438
      \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0438 \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u043B\u044C\u043D\u043E
      \u0434\u043B\u044F \u0432\u0430\u0441."
    m_Metadata:
      m_Items: []
  - m_Id: 5490253975552
    m_Localized: "\u0423\u0447\u0430\u0441\u0442\u043A\u043E\u0432\u044B\u0439? \u0410...
      \u044F \u043D\u0435 \u043F\u043E\u043B\u0443\u0447\u0430\u043B\u0430 \u043D\u0438\u043A\u0430\u043A\u0438\u0445
      \u0443\u0432\u0435\u0434\u043E\u043C\u043B\u0435\u043D\u0438\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 5522499784704
    m_Localized: "\u041E\u043D \u0441\u043A\u0430\u0437\u0430\u043B \u0447\u0442\u043E-\u0442\u043E
      \u043E\u0431 \u0410\u0440\u0442\u0451\u043C\u0435?"
    m_Metadata:
      m_Items: []
  - m_Id: 5537968377856
    m_Localized: "\u0423\u0432\u044B, \u043D\u0435\u0442, \u0422\u043E\u043B\u044C\u043A\u043E
      \u043F\u043E\u0434\u0447\u0435\u0440\u043A\u043D\u0443\u043B, \u0447\u0442\u043E
      \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E \u043F\u0435\u0440\u0435\u0434\u0430\u0442\u044C
      \u044D\u0442\u043E \u0432\u0430\u043C \u043B\u0438\u0447\u043D\u043E \u0432
      \u0440\u0443\u043A\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 5551692140544
    m_Localized: "\u0410 \u0435\u0441\u043B\u0438 \u0443 \u043C\u0435\u043D\u044F
      \u0432\u043E\u0437\u043D\u0438\u043A\u043D\u0443\u0442 \u0432\u043E\u043F\u0440\u043E\u0441\u044B
      \u043A \u043D\u0435\u043C\u0443 \u043B\u0438\u0447\u043D\u043E?"
    m_Metadata:
      m_Items: []
  - m_Id: 5567131373568
    m_Localized: "\u041E\u043D \u0441\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E
      \u0431\u0443\u0434\u0435\u0442 \u0432 \u043E\u0444\u0438\u0441\u0435 \u043F\u043E\u0441\u043B\u0435
      \u0434\u0432\u0443\u0445 \u0447\u0430\u0441\u043E\u0432 \u0434\u043D\u044F.
      \u0412\u044B \u0441\u043C\u043E\u0436\u0435\u0442\u0435 \u043D\u0430\u0439\u0442\u0438
      \u0435\u0433\u043E \u0442\u0430\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 5595044466688
    m_Localized: "\u0425\u043E\u0440\u043E\u0448\u043E. \u0421\u043F\u0430\u0441\u0438\u0431\u043E,
      \u0412\u0438\u043A\u0442\u043E\u0440. \u0412\u044B \u0445\u043E\u0440\u043E\u0448\u0438\u0439
      \u0447\u0435\u043B\u043E\u0432\u0435\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 5614438928384
    m_Localized: "\u0414\u043E\u0431\u0440\u043E\u0433\u043E \u0432\u0430\u043C \u0434\u043D\u044F,
      \u0410\u043D\u043D\u0430. \u0418 \u044F \u0443\u0432\u0435\u0440\u0435\u043D,
      \u0410\u0440\u0442\u0451\u043C \u043E\u0431\u044F\u0437\u0430\u0442\u0435\u043B\u044C\u043D\u043E
      \u0436\u0438\u0432. \u041D\u0435 \u0432\u0435\u0448\u0430\u0439\u0442\u0435
      \u043D\u043E\u0441."
    m_Metadata:
      m_Items: []
  - m_Id: 5633669812224
    m_Localized: "\u041A\u043E\u043D\u0435\u0447\u043D\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 6382302744576
    m_Localized: "\u0414\u043E\u0431\u0440\u044B\u0439 \u0434\u0435\u043D\u044C.
      \u041C\u043D\u0435 \u043D\u0443\u0436\u043D\u043E \u043F\u043E\u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C
      \u0441 \u0432\u0430\u043C\u0438 \u043E \u043C\u043E\u0435\u043C \u043C\u0443\u0436\u0435,
      \u0410\u0440\u0442\u0451\u043C\u0435. \u042F \u0441\u043B\u044B\u0448\u0430\u043B\u0430,
      \u043E\u043D \u0447\u0430\u0441\u0442\u043E \u043F\u043E\u0441\u0435\u0449\u0430\u043B
      \u0432\u0430\u0448\u0443 \u043B\u0430\u0432\u043A\u0443, \u043D\u0443... \u043F\u0435\u0440\u0435\u0434
      \u0442\u0435\u043C, \u043A\u0430\u043A \u043F\u0440\u043E\u043F\u0430\u043B.
      \u0414\u0443\u043C\u0430\u044E, \u043E\u043D \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0441\u044F
      \u0443 \u0432\u0430\u0441 \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u0430\u043C\u0438,
      \u0447\u0442\u043E \u0441\u0432\u044F\u0437\u0430\u043D\u044B \u0441 \u0440\u0430\u043D\u043D\u0438\u043C\u0438
      \u044D\u043F\u043E\u0445\u0430\u043C\u0438 \u043D\u0430 \u0423\u0440\u0430\u043B\u0435,
      \u043E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0434\u043E \u043D\u0430\u0448\u0435\u0439
      \u044D\u0440\u044B. \u041C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C,
      \u0432\u044B \u043F\u043E\u043C\u043D\u0438\u0442\u0435 \u0435\u0433\u043E?"
    m_Metadata:
      m_Items: []
  - m_Id: 6499239940096
    m_Localized: "\u0414\u0430, \u043A\u0430\u0436\u0435\u0442\u0441\u044F, \u043F\u043E\u043C\u043D\u044E.
      \u0414\u0430\u0432\u043D\u0435\u043D\u044C\u043A\u043E \u044F \u0435\u0433\u043E
      \u0443\u0436\u0435 \u043D\u0435 \u0432\u0438\u0434\u0435\u043B. \u0412\u0430\u0448
      \u043C\u0443\u0436 \u043A\u0440\u0430\u0439\u043D\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0439
      \u0441\u043E\u0431\u0435\u0441\u0435\u0434\u043D\u0438\u043A, \u0430 \u0442\u0430\u043A\u0438\u043C
      \u043B\u044E\u0434\u044F\u043C, \u043A\u0430\u043A \u044F, \u0442\u0430\u043A\u043E\u0433\u043E
      \u043F\u043E\u0440\u043E\u0439 \u043A\u0430\u043A \u0440\u0430\u0437 \u0441\u0438\u043B\u044C\u043D\u043E
      \u043D\u0435 \u0445\u0432\u0430\u0442\u0430\u0435\u0442. \u041D\u0443, \u0432\u044B
      \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0442\u0435, \u043E \u0447\u0451\u043C
      \u044F: \u043A\u043E \u043C\u043D\u0435 \u0432\u0435\u0434\u044C \u043D\u0435
      \u043E\u0441\u043E\u0431\u043E \u0447\u0430\u0441\u0442\u043E \u0437\u0430\u0433\u043B\u044F\u0434\u044B\u0432\u0430\u044E\u0442
      \u043F\u043E\u0441\u0435\u0442\u0438\u0442\u0435\u043B\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 6512695267328
    m_Localized: "\u0414\u0430-\u0434\u0430. \u0410 \u0410\u0440\u0442\u0451\u043C,
      \u043C\u043E\u0436\u0435\u0442, \u0441\u043F\u0440\u0430\u0448\u0438\u0432\u0430\u043B
      \u0438\u043B\u0438 \u0438\u0441\u043A\u0430\u043B \u0447\u0442\u043E-\u0442\u043E
      \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u043E\u0435?"
    m_Metadata:
      m_Items: []
  - m_Id: 6525982822400
    m_Localized: "\u041D\u0443, \u0435\u0433\u043E \u0447\u0430\u0441\u0442\u043E
      \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043E\u0432\u0430\u043B\u0438 \u043D\u0430\u0445\u043E\u0434\u043A\u0438,
      \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0435 \u0441 \u0434\u0440\u0435\u0432\u043D\u0438\u043C\u0438
      \u043F\u043B\u0435\u043C\u0435\u043D\u0430\u043C\u0438, \u0438\u043B\u0438
      \u0434\u0430\u0436\u0435 \u0441 \u043A\u0430\u043A\u0438\u043C-\u0442\u043E
      \u043D\u0430\u0440\u043E\u0434\u043E\u043C, \u044F \u0431\u044B \u0441\u043A\u0430\u0437\u0430\u043B,
      \u0430 \u0442\u043E \u0438 \u0446\u0435\u043B\u043E\u0439 \u0446\u0438\u0432\u0438\u043B\u0438\u0437\u0430\u0446\u0438\u0435\u0439."
    m_Metadata:
      m_Items: []
  - m_Id: 6539803054080
    m_Localized: "\u041E \u043A\u0430\u043A\u0438\u0445 \u043F\u043B\u0435\u043C\u0435\u043D\u0430\u0445
      \u0440\u0435\u0447\u044C? \u041A\u0430\u043A\u043E\u0439-\u0442\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u044B\u0439
      \u043D\u0430\u0440\u043E\u0434 \u043D\u0430 \u0434\u0440\u0435\u0432\u043D\u0435\u043C
      \u0423\u0440\u0430\u043B\u0435? \u0418, \u043C\u043E\u0436\u0435\u0442 \u043E\u043D
      \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043B \u0447\u0442\u043E-\u0442\u043E,
      \u0447\u0442\u043E \u043E\u043D \u0441\u0443\u043C\u0435\u043B \u043D\u0430\u0439\u0442\u0438
      \u0438\u043B\u0438 \u0441\u043E\u0431\u0438\u0440\u0430\u043B\u0441\u044F \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u044C
      \u0431\u043E\u043B\u0435\u0435 \u043F\u043E\u0434\u0440\u043E\u0431\u043D\u043E?"
    m_Metadata:
      m_Items: []
  - m_Id: 6555242287104
    m_Localized: "\u041E\u043D \u0438\u0441\u043A\u0430\u043B \u0441\u043B\u0435\u0434\u044B
      \u043A\u0430\u043A\u043E\u0439-\u0442\u043E \u0434\u0440\u0435\u0432\u043D\u0435\u0439
      \u0446\u0438\u0432\u0438\u043B\u0438\u0437\u0430\u0446\u0438\u0438. \u041F\u0440\u0438
      \u044D\u0442\u043E\u043C, \u043A\u0430\u0436\u0435\u0442\u0441\u044F, \u043E\u043D
      \u0431\u044B\u043B \u0443\u0432\u0435\u0440\u0435\u043D, \u0447\u0442\u043E
      \u043D\u0430 \u0423\u0440\u0430\u043B\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0438
      \u043F\u043B\u0435\u043C\u0435\u043D\u0430, \u0441\u0445\u043E\u0436\u0438\u0435
      \u0432 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0430\u0441\u043F\u0435\u043A\u0442\u0430\u0445
      \u0432\u0435\u0440\u044B \u0441 \u0430\u0440\u0438\u0439\u0441\u043A\u0438\u043C\u0438,
      \u0438, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0434\u0430\u0436\u0435
      \u0433\u043E\u0440\u0430\u0437\u0434\u043E \u0431\u043E\u043B\u0435\u0435 \u0440\u0430\u0437\u0432\u0438\u0432\u0448\u0438\u0435\u0441\u044F,
      \u0447\u0435\u043C \u043C\u044B \u0441\u0435\u0431\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u043C.
      \n\u0412\u0430\u0448 \u043C\u0443\u0436 \u0432\u0435\u0440\u0438\u043B, \u0447\u0442\u043E
      \u044D\u0442\u0438 \u043B\u044E\u0434\u0438 \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0438
      \u043F\u043E\u0441\u043B\u0435 \u0441\u0435\u0431\u044F \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B
      \u0438 \u043E\u0440\u0443\u0434\u0438\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
      \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043E\u043F\u0435\u0440\u0435\u0436\u0430\u043B\u0438
      \u0441\u0432\u043E\u0451 \u0432\u0440\u0435\u043C\u044F. \u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
      \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0438 \u043E\u0441\u0442\u0430\u043B\u0438\u0441\u044C
      \u0432 \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E \u0438\u0445
      \u043F\u0440\u0435\u0434\u043A\u0430\u043C, \u043E\u0434\u043D\u0430\u043A\u043E
      \u0431\u043E\u043B\u044C\u0448\u0430\u044F \u0438\u0445 \u0447\u0430\u0441\u0442\u044C
      \u0431\u0435\u0441\u0441\u043B\u0435\u0434\u043D\u043E \u0438\u0441\u0447\u0435\u0437\u043B\u0430,
      \u0442\u0430\u043A\u0436\u0435, \u043A\u0430\u043A \u0438 \u043F\u043E\u0447\u0442\u0438
      \u0432\u0441\u0435 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043D\u0438\u044F
      \u043E\u0431 \u0438\u0445 \u043A\u0443\u043B\u044C\u0442\u0443\u0440\u0435.
      \u042D\u0442\u043E \u0435\u0433\u043E \u0437\u0430\u0445\u0432\u0430\u0442\u0438\u043B\u043E.
      \u041E\u043D \u0445\u043E\u0442\u0435\u043B \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C,
      \u0447\u0442\u043E \u044D\u0442\u0430 \u0446\u0438\u0432\u0438\u043B\u0438\u0437\u0430\u0446\u0438\u044F
      \u043D\u0435 \u0438\u0441\u0447\u0435\u0437\u043B\u0430 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E,
      \u0430 \u0431\u044B\u043B\u0430 \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D\u0430
      \u0438\u043B\u0438 \u0438\u0441\u0447\u0435\u0437\u043B\u0430 \u043F\u043E
      \u043A\u0430\u043A\u043E\u0439-\u0442\u043E \u043D\u0435\u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043C\u043E\u0439
      \u043F\u0440\u0438\u0447\u0438\u043D\u0435. \u0418\u043C\u0435\u043D\u043D\u043E
      \u044D\u0442\u0443 \u043F\u0440\u0438\u0447\u0438\u043D\u0443 \u0438 \u0438\u0441\u043A\u0430\u043B
      \u0410\u0440\u0442\u0451\u043C \u0432 \u043F\u0435\u0440\u0432\u0443\u044E
      \u043E\u0447\u0435\u0440\u0435\u0434\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 6571444883456
    m_Localized: "\u042F\u2026 \u042F \u043D\u0435 \u0441\u043C\u043E\u0433 \u043F\u043E\u043C\u043E\u0447\u044C
      \u0435\u043C\u0443. \u041C\u043D\u043E\u0433\u043E \u0432\u0440\u0435\u043C\u0435\u043D\u0438
      \u043E\u043D \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B, \u0438\u0437\u0443\u0447\u0430\u044F
      \u0442\u0435 \u0441\u0442\u0430\u0440\u044B\u0435 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B,
      \u043D\u043E \u0442\u0430\u043A \u0438 \u043D\u0435 \u0441\u043C\u043E\u0433
      \u0432\u044B\u044F\u0441\u043D\u0438\u0442\u044C, \u0447\u0442\u043E \u044D\u0442\u043E
      \u0431\u044B\u043B \u0437\u0430 \u043D\u0430\u0440\u043E\u0434, \u0447\u0442\u043E
      \u0436\u0438\u043B \u0437\u0434\u0435\u0441\u044C. \u0418 \u043F\u043E\u0447\u0435\u043C\u0443
      \u0438\u0445 \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u0438 \u0431\u044B\u043B\u0438
      \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E \u043F\u0440\u043E\u0434\u0432\u0438\u043D\u0443\u0442\u044B\u043C\u0438
      \u0434\u043B\u044F \u0442\u043E\u0439 \u044D\u043F\u043E\u0445\u0438? \u0418,
      \u043A\u043E\u043D\u0435\u0447\u043D\u043E, \u0410\u0440\u0442\u0451\u043C\u0430
      \u0432 \u043F\u0435\u0440\u0432\u0443\u044E \u043E\u0447\u0435\u0440\u0435\u0434\u044C
      \u0432\u043E\u043B\u043D\u043E\u0432\u0430\u043B\u043E: \u043F\u043E\u0447\u0435\u043C\u0443
      \u0438 \u043A\u0443\u0434\u0430 \u043E\u043D\u0438 \u0443\u0448\u043B\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 6587014139904
    m_Localized: "\u041E\u043D \u043D\u0435 \u043D\u0430\u0448\u0451\u043B \u0441\u043E\u0432\u0441\u0435\u043C
      \u043D\u0438\u0447\u0435\u0433\u043E? \u0414\u043E\u043B\u0436\u043D\u044B
      \u0436\u0435 \u0431\u044B\u043B\u0438 \u0431\u044B\u0442\u044C \u0443 \u043D\u0435\u0433\u043E
      \u043A\u0430\u043A\u0438\u0435-\u0442\u043E \u0437\u0430\u0446\u0435\u043F\u043A\u0438.
      \u041C\u043E\u0436\u0435\u0442 \u043E\u043D \u043D\u0430\u043C\u0435\u0440\u0435\u0432\u0430\u043B\u0441\u044F
      \u0440\u0430\u0437\u044B\u0441\u043A\u0430\u0442\u044C \u0447\u0442\u043E-\u0442\u043E
      \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u043E\u0435 \u0438 \u0432\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u0435\u0435
      \u0438\u0437\u0443\u0447\u0438\u0442\u044C \u043D\u0430 \u043C\u0435\u0441\u0442\u0435?
      \u041E\u043D \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435 \u0443\u043F\u043E\u043C\u0438\u043D\u0430\u043B?"
    m_Metadata:
      m_Items: []
  - m_Id: 6601912307712
    m_Localized: "\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 6647881879552
    m_Localized: "\u0415\u0441\u0442\u044C \u043E\u0434\u043D\u043E \u043C\u0435\u0441\u0442\u043E,
      \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u044F \u043F\u043E\u0441\u043E\u0432\u0435\u0442\u043E\u0432\u0430\u043B
      \u0435\u043C\u0443, \u043F\u0435\u0440\u0435\u0434 \u0442\u0435\u043C, \u043A\u0430\u043A
      \u043E\u043D \u0443\u0448\u0451\u043B. \u042D\u0442\u043E \u0441\u0442\u0430\u0440\u044B\u0439
      \u043C\u0443\u0437\u0435\u0439, \u0410\u0440\u043A\u0430\u0438\u043C. \u041E\u043D
      \u0434\u0430\u0432\u043D\u043E \u0437\u0430\u043A\u0440\u044B\u0442, \u043D\u043E\u2026
      \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E, \u0442\u0430\u043C \u0432\u0441\u0451
      \u0435\u0449\u0451 \u043E\u0441\u0442\u0430\u043B\u0438\u0441\u044C \u043A\u0430\u043A\u0438\u0435-\u0442\u043E
      \u0441\u043B\u0435\u0434\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
      \u043C\u043E\u0433\u043B\u0438 \u0431\u044B \u0435\u043C\u0443 \u043F\u043E\u043C\u043E\u0447\u044C
      \u0432\u044B\u0439\u0442\u0438 \u043D\u0430 \u043D\u0443\u0436\u043D\u044B\u0439
      \u0441\u043B\u0435\u0434. \u041D\u043E \u044F \u043D\u0435 \u0443\u0432\u0435\u0440\u0435\u043D,
      \u0447\u0442\u043E \u043E\u043D \u0447\u0442\u043E-\u0442\u043E \u0435\u0449\u0451
      \u0442\u0430\u043C \u043C\u043E\u0433 \u043D\u0430\u0439\u0442\u0438. \u041C\u0435\u0441\u0442\u043E
      \u0434\u0430\u0432\u043D\u043E \u0437\u0430\u0431\u0440\u043E\u0448\u0435\u043D\u043E,
      \u0434\u0430 \u0438, \u0447\u0435\u0441\u0442\u043D\u043E \u0433\u043E\u0432\u043E\u0440\u044F,
      \u0432\u0441\u0451, \u0447\u0442\u043E \u0442\u0430\u043C \u0435\u0441\u0442\u044C
      \u2014 \u044D\u0442\u043E \u043F\u044B\u043B\u044C \u0434\u0430 \u043E\u0441\u0442\u0430\u043D\u043A\u0438
      \u043F\u0440\u043E\u0448\u043B\u043E\u0433\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 6662914265088
    m_Localized: "\u041C\u0443\u0437\u0435\u0439 \u0410\u0440\u043A\u0430\u0438\u043C?
      \u0410 \u0433\u0434\u0435 \u044D\u0442\u043E?"
    m_Metadata:
      m_Items: []
  - m_Id: 6676038242304
    m_Localized: "\u042D\u0442\u043E \u043D\u0430 \u043E\u043A\u0440\u0430\u0438\u043D\u0435
      \u0432 \u0437\u0430\u0431\u0440\u043E\u0448\u0435\u043D\u043D\u043E\u0439 \u0447\u0430\u0441\u0442\u0438
      \u0433\u043E\u0440\u043E\u0434\u0430 \u0437\u0430 \u0427\u0438\u0441\u0442\u043E\u043F\u043E\u043B\u044C\u0441\u043A\u043E\u0439.
      5 \u043A\u0438\u043B\u043E\u043C\u0435\u0442\u0440\u043E\u0432 \u043F\u0440\u0438\u043C\u0435\u0440\u043D\u043E
      \u0434\u0430\u043B\u044C\u0448\u0435 \u043F\u043E \u0434\u043E\u0440\u043E\u0433\u0435.
      \n\u0422\u0430\u043C \u0443\u0436\u0435 \u0434\u0430\u0432\u043D\u0435\u043D\u044C\u043A\u043E
      \u043D\u0438\u043A\u0442\u043E \u0440\u044F\u0434\u043E\u043C \u043D\u0435
      \u0436\u0438\u0432\u0451\u0442. \u041C\u0435\u0441\u0442\u043D\u043E\u0441\u0442\u044C
      \u043E\u0442\u0434\u0430\u043B\u0451\u043D\u043D\u0430\u044F, \u0438 \u0431\u044B\u043B\u0438
      \u0441\u0438\u043B\u044C\u043D\u044B\u0435 \u043F\u043E\u0436\u0430\u0440\u044B
      \u043B\u0435\u0442 \u0441\u0442\u043E \u043D\u0430\u0437\u0430\u0434. \u0421\u0442\u0440\u0430\u043D\u043D\u044B\u0435
      \u0431\u044B\u043B\u0438 \u0441\u043B\u0443\u0447\u0430\u0438. \u041E \u043D\u0438\u0445
      \u0434\u043E \u0441\u0438\u0445 \u043F\u043E\u0440 \u0441\u0442\u0440\u043E\u044F\u0442
      \u0433\u0438\u043F\u043E\u0442\u0435\u0437\u044B. \u041F\u043E\u043C\u043D\u0438\u0442\u0441\u044F,
      \u0447\u0438\u0442\u0430\u043B, \u0447\u0442\u043E \u0442\u043E\u0433\u0434\u0430
      \u0434\u0430\u0436\u0435 \u0443\u0447\u0451\u043D\u044B\u0435 \u0441\u043E
      \u0432\u0441\u0435\u0433\u043E \u0441\u0432\u0435\u0442\u0430 \u043F\u0440\u0438\u0435\u0437\u0436\u0430\u043B\u0438,
      \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u044C \u044D\u0442\u043E\u0442
      \u0444\u0435\u043D\u043E\u043C\u0435\u043D. \n\u0420\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u044E\u0442,
      \u0447\u0442\u043E \u043F\u0430\u0440\u0443 \u0440\u0430\u0437 \u043E\u0433\u043E\u043D\u044C
      \u0442\u0430\u043C \u0432\u0441\u043F\u044B\u0445\u0438\u0432\u0430\u043B \u043F\u0440\u043E\u0441\u0442\u043E
      \u0432 \u0432\u043E\u0437\u0434\u0443\u0445\u0435, \u043F\u0440\u044F\u043C\u043E
      \u0438\u0437 \u043D\u0438\u043E\u0442\u043A\u0443\u0434\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 6698884616192
    m_Localized: "\u041D\u0443, \u0432 \u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442,
      \u043A\u0430\u043A \u043C\u043D\u0435 \u043F\u043E\u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C,
      \u043E\u043D \u0437\u0430\u0448\u0451\u043B \u0432 \u0442\u0443\u043F\u0438\u043A,
      \u0438 \u043E\u0442\u0447\u0430\u044F\u043D\u043D\u043E \u0438\u0441\u043A\u0430\u043B
      \u0445\u043E\u0442\u044C \u043A\u0430\u043A\u0438\u0435-\u0442\u043E \u0437\u0430\u0446\u0435\u043F\u043A\u0438
      \u0434\u043B\u044F \u0441\u0432\u043E\u0435\u0433\u043E \u0440\u0430\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F
      \u0434\u0440\u0435\u0432\u043D\u0438\u0445. \u0410 \u0435\u0441\u043B\u0438
      \u043E\u043D \u0432\u0441\u0451 \u0436\u0435 \u0431\u044B\u043B \u0442\u0430\u043C
      \u0438 \u043D\u0435 \u0432\u0435\u0440\u043D\u0443\u043B\u0441\u044F, \u0442\u043E,
      \u0432\u0435\u0440\u043E\u044F\u0442\u043D\u043E, \u043C\u043E\u0433 \u043D\u0430\u0439\u0442\u0438
      \u043F\u043E\u0434\u0441\u043A\u0430\u0437\u043A\u0438 \u043A \u0441\u0432\u043E\u0438\u043C
      \u0442\u0435\u043E\u0440\u0438\u044F\u043C. \u0425\u043E\u0442\u044F, \u043F\u0440\u0438\u0437\u043D\u0430\u044E\u0441\u044C,
      \u044F \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0430\u043B \u0435\u043C\u0443
      \u043F\u0440\u043E \u044D\u0442\u043E\u0442 \u043C\u0443\u0437\u0435\u0439
      \u0447\u0438\u0441\u0442\u043E, \u0447\u0442\u043E\u0431\u044B \u043A\u0430\u043A-\u0442\u043E
      \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u0430\u0442\u044C. \u0428\u0430\u043D\u0441\u043E\u0432,
      \u0447\u0442\u043E \u0442\u0430\u043C \u043F\u0440\u0430\u0432\u0434\u0430
      \u043C\u043E\u0433\u043B\u043E \u0447\u0442\u043E-\u0442\u043E \u043D\u0430\u0439\u0442\u0438\u0441\u044C,
      \u043F\u043E\u0447\u0442\u0438 \u043D\u0438\u043A\u0430\u043A\u0438\u0445."
    m_Metadata:
      m_Items: []
  - m_Id: 6688080089088
    m_Localized: "\u0412\u044B \u0434\u0443\u043C\u0430\u0435\u0442\u0435, \u0410\u0440\u0442\u0451\u043C
      \u0442\u0443\u0434\u0430 \u0432\u0441\u0451 \u0436\u0435 \u043F\u043E\u0435\u0445\u0430\u043B?"
