    m_Localized: "\u0413\u043E\u0440\u043E\u0434 \u0438 \u043F\u043E\u0433\u0440\u0435\u0431\u0430\u043B\u044C\u043D\u044B\u0435
      \u0441\u043E\u043E\u0440\u0443\u0436\u0435\u043D\u0438\u044F \u0432 \u043F\u043B\u0430\u043D\u0435
      \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u044E\u0442 \u0441\u043E\u0431\u043E\u0439
      \u0441\u043E\u0447\u0435\u0442\u0430\u043D\u0438\u0435 \u043A\u0440\u0443\u0433\u0430
      \u0438 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 9264345133682688
    m_Localized: "\u041F\u043E\u0441\u0435\u043B\u0435\u043D\u0438\u0435 \u0410\u0440\u043A\u0430\u0438\u043C
      \u043E\u043A\u0440\u0443\u0436\u0430\u043B \u0434\u0432\u0443\u0445 \u043C\u0435\u0442\u0440\u043E\u0432\u044B\u0439
      \u043E\u0431\u0432\u043E\u0434\u043D\u043E\u0439 \u0440\u043E\u0432, \u0437\u0430\u043F\u043E\u043B\u043D\u044F\u0432\u0448\u0438\u0439\u0441\u044F
      \u0432\u043E\u0434\u043E\u0439. \u0412\u043D\u0435\u0448\u043D\u044F\u044F
      \u0441\u0442\u0435\u043D\u0430 \u043F\u0440\u0438 \u0432\u044B\u0441\u043E\u0442\u0435
      5,5 \u043C \u0438\u043C\u0435\u043B\u0430 \u0430\u0436 \u043F\u044F\u0442\u0438\u043C\u0435\u0442\u0440\u043E\u0432\u0443\u044E
      \u0448\u0438\u0440\u0438\u043D\u0443."
    m_Metadata:
      m_Items: []
  - m_Id: 9264356953231360
    m_Localized: "\u0412\u0441\u0435 \u0436\u0438\u043B\u0438\u0449\u0430, \u043F\u0440\u0438\u043C\u044B\u043A\u0430\u0432\u0448\u0438\u0435
      \u043A \u0432\u043D\u0435\u0448\u043D\u0435\u0439 \u0441\u0442\u0435\u043D\u0435,
      \u043A\u0430\u043A \u0434\u043E\u043B\u044C\u043A\u0438 \u043B\u0438\u043C\u043E\u043D\u0430,
      \u0438\u043C\u0435\u043B\u0438 \u0432\u044B\u0445\u043E\u0434\u044B \u043D\u0430
      \u0433\u043B\u0430\u0432\u043D\u0443\u044E \u0443\u043B\u0438\u0446\u0443.
      \u0412\u0441\u0435\u0433\u043E \u0436\u0438\u043B\u0438\u0449 \u0432\u043D\u0435\u0448\u043D\u0435\u0433\u043E
      \u043A\u0440\u0443\u0433\u0430 \u0431\u044B\u043B\u043E \u043E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D\u043E
      35."
    m_Metadata:
      m_Items: []
  - m_Id: 9264370198843392
    m_Localized: "\u0421\u0440\u0435\u0434\u0438 \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u0445
      \u0440\u043E\u0434\u043E\u0432 \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438
      \u043F\u0440\u0435\u043E\u0431\u043B\u0430\u0434\u0430\u043B\u0438 \u043C\u0435\u0442\u0430\u043B\u043B\u0443\u0440\u0433\u0438\u044F
      (\u0431\u0440\u043E\u043D\u0437\u0430), \u0441\u043A\u043E\u0442\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E
      (\u0430 \u0442\u0430\u043A\u0436\u0435, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
      \u043A\u043E\u043D\u0435\u0432\u043E\u0434\u0441\u0442\u0432\u043E) \u0438
      \u043E\u0445\u043E\u0442\u0430."
    m_Metadata:
      m_Items: []
  - m_Id: 9264388033024000
    m_Localized: "\u0411\u044B\u0442, \u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u0443\u0440\u0430
      \u0438 \u043C\u0435\u0441\u0442\u0430 \u043F\u043E\u0433\u0440\u0435\u0431\u0435\u043D\u0438\u044F
      \u0438\u043C\u0435\u043B\u0438 \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
      \u0442\u0435\u0441\u043D\u0443\u044E \u0441\u0432\u044F\u0437\u044C \u0441
      \u0432\u0435\u0440\u043E\u0432\u0430\u043D\u0438\u044F\u043C\u0438 (\u0432\u043A\u043B\u044E\u0447\u0430\u044F
      \u043A\u0443\u043B\u044C\u0442 \u043E\u0433\u043D\u044F), \u0440\u0438\u0442\u0443\u0430\u043B\u0430\u043C\u0438
      \u0438 \u0441\u0430\u043A\u0440\u0430\u043B\u044C\u043D\u044B\u043C\u0438 \u0441\u0438\u043C\u0432\u043E\u043B\u0430\u043C\u0438
      \u0438 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F\u043C\u0438."
