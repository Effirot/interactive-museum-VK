  - m_Id: 10009553620992
    m_Localized: "\u042D\u0442\u043E \u043F\u044B\u043B\u044C? \u0414\u0430, \u043D\u0430\u0434\u043E
      \u0431\u044B \u043D\u0435 \u0437\u0430\u0431\u044B\u0442\u044C \u043F\u043E\u043C\u044B\u0442\u044C
      \u0435\u0451 \u0432\u0435\u0447\u0435\u0440\u043E\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 10095088062464
    m_Localized: "\u0410\u0440\u0442\u0451\u043C \u043F\u043E\u0447\u0435\u043C\u0443-\u0442\u043E
      \u043D\u0435 \u043B\u044E\u0431\u0438\u0442 \u0445\u0440\u0430\u043D\u0438\u0442\u044C
      \u0441\u0432\u043E\u0438 \u043C\u044B\u0441\u043B\u0438 \u0432 \u0443\u0441\u0442\u0440\u043E\u0439\u0441\u0442\u0432\u0430\u0445.
      \u0425\u043E\u0442\u044C \u044D\u0442\u043E \u0438 \u0441\u0442\u0430\u0440\u043E\u043C\u043E\u0434\u043D\u043E,
      \u044F \u0440\u0430\u0434\u0430, \u0447\u0442\u043E \u0435\u043C\u0443 \u043F\u0440\u0438\u0433\u043E\u0434\u0438\u043B\u0441\u044F
      \u043C\u043E\u0439 \u043F\u043E\u0434\u0430\u0440\u043E\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 10164881281024
    m_Localized: "\u041A\u043E\u0433\u0434\u0430 \u044F \u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0439
      \u0440\u0430\u0437 \u0435\u0451 \u0437\u0430\u043F\u0440\u0430\u0432\u043B\u044F\u043B\u0430?
      \u041A\u0430\u0436\u0435\u0442\u0441\u044F, \u0443\u0436\u0435 \u043F\u043E\u043B\u0433\u043E\u0434\u0430
      \u043A\u0430\u043A \u044D\u0442\u043E \u0434\u0435\u043B\u0430\u043B \u0442\u043E\u043B\u044C\u043A\u043E
      \u0410\u0440\u0442\u0451\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 10464824348672
    m_Localized: "\u041E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0435
      \u0443\u0432\u0435\u0434\u043E\u043C\u043B\u0435\u043D\u0438\u0435. \n\u041E\u0442:
      \u0421\u043B\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435 \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435
      \n\u0414\u0430\u0442\u0430: 05.06.2322. \n\u0414\u043B\u044F: \u0410\u043D\u043D\u044B
      \u041A\u0435\u0440\u043C\u0430\u043D \n\u0422\u0435\u043C\u0430: \u041F\u0440\u0438\u0437\u043D\u0430\u043D\u0438\u0435
      \u0410\u0440\u0442\u0451\u043C\u0430 \u041A\u0435\u0440\u043C\u0430\u043D \u043F\u0440\u043E\u043F\u0430\u0432\u0448\u0438\u043C
      \u0431\u0435\u0437 \u0432\u0435\u0441\u0442\u0438 \n\u0423\u0432\u0430\u0436\u0430\u0435\u043C\u0430\u044F
      \u0410\u043D\u043D\u0430 \u041A\u0435\u0440\u043C\u0430\u043D \u041D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u043C
      \n\u0443\u0432\u0435\u0434\u043E\u043C\u043B\u044F\u0435\u043C \u0412\u0430\u0441,
      \u0447\u0442\u043E \u0432 \u0445\u043E\u0434\u0435 \u0434\u043E\u043B\u0433\u0438\u0445
      \u0438 \u0442\u0449\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0445 \u0441\u044B\u0441\u043A\u043D\u044B\u0445
      \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439, \u043F\u0440\u043E\u0432\u0435\u0434\u0451\u043D\u043D\u044B\u0445
      \u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u043C\u0438
      \u043E\u0440\u0433\u0430\u043D\u0430\u043C\u0438, \u0430 \u0442\u0430\u043A\u0436\u0435
      \u0432 \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0438
      \u0441 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u043D\u043E\u0439
      \u043F\u0440\u043E\u0446\u0435\u0434\u0443\u0440\u043E\u0439, \u0412\u0430\u0448
      \u0441\u0443\u043F\u0440\u0443\u0433, \u0410\u0440\u0442\u0451\u043C \u041A\u0435\u0440\u043C\u0430\u043D,
      \u0432 \u0438\u0442\u043E\u0433\u0435 \u0431\u044B\u043B \u043F\u0440\u0438\u0437\u043D\u0430\u043D
      \u043F\u0440\u043E\u043F\u0430\u0432\u0448\u0438\u043C \u0431\u0435\u0437 \u0432\u0435\u0441\u0442\u0438.
      \n\u041D\u0435\u0441\u043C\u043E\u0442\u0440\u044F \u043D\u0430 \u0432\u0441\u0435
      \u0443\u0441\u0438\u043B\u0438\u044F, \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u0435
      \u043D\u0430 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u043B\u0435\u043D\u0438\u0435
      \u0435\u0433\u043E \u043C\u0435\u0441\u0442\u043E\u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F,
      \u0430 \u0442\u0430\u043A\u0436\u0435 \u043C\u043D\u043E\u0433\u043E\u0447\u0438\u0441\u043B\u0435\u043D\u043D\u044B\u0435
      \u043F\u043E\u0438\u0441\u043A\u043E\u0432\u044B\u0435 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438,
      \u043D\u0435 \u0443\u0434\u0430\u043B\u043E\u0441\u044C \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
      \u043A\u0430\u043A\u0438\u0445-\u043B\u0438\u0431\u043E \u0441\u0432\u0438\u0434\u0435\u0442\u0435\u043B\u044C\u0441\u0442\u0432
      \u043E \u0435\u0433\u043E \u0441\u0443\u0434\u044C\u0431\u0435 \u0438\u043B\u0438
      \u043C\u0435\u0441\u0442\u043E\u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0438,
      \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043C\u043E\u0433\u043B\u0438 \u0431\u044B
      \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0434\u0438\u0442\u044C \u0435\u0433\u043E
      \u0436\u0438\u0437\u043D\u044C. \u0417\u0430 \u043F\u0435\u0440\u0438\u043E\u0434
      \u0440\u0430\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u044F,
      \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u043A\u043B\u044E\u0447\u0430\u043B
      \u0441\u0431\u043E\u0440 \u043F\u043E\u043A\u0430\u0437\u0430\u043D\u0438\u0439,
      \u043E\u0441\u043C\u043E\u0442\u0440 \u043C\u0435\u0441\u0442 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0433\u043E
      \u043D\u0430\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u044F \u0438 \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0443
      \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0445 \u0433\u0438\u043F\u043E\u0442\u0435\u0437,
      \u043D\u0435 \u0431\u044B\u043B\u043E \u0432\u044B\u044F\u0432\u043B\u0435\u043D\u043E
      \u043D\u0438 \u043E\u0434\u043D\u043E\u0439 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0439
      \u0437\u0430\u0446\u0435\u043F\u043A\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 10527902486528
    m_Localized: "\u0412 \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0438
      \u0441 \u0437\u0430\u043A\u043E\u043D\u043E\u0434\u0430\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u043E\u043C,
      \u043F\u043E\u0441\u043B\u0435 90 \u0434\u043D\u0435\u0439 \u0441 \u043C\u043E\u043C\u0435\u043D\u0442\u0430
      \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u043E\u0431\u0440\u0430\u0449\u0435\u043D\u0438\u044F,
      \u0441 \u0443\u0447\u0451\u0442\u043E\u043C \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u044F
      \u0444\u0430\u043A\u0442\u043E\u0432 \u043E \u0435\u0433\u043E \u0441\u0443\u0434\u044C\u0431\u0435
      \u0438 \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0433\u043E \u043E\u0442\u0441\u0443\u0442\u0441\u0442\u0432\u0438\u044F
      \u0441\u043B\u0435\u0434\u043E\u0432, \u0410\u0440\u0442\u0451\u043C \u041A\u0435\u0440\u043C\u0430\u043D
      \u043F\u0440\u0438\u0437\u043D\u0430\u043D \u043F\u0440\u043E\u043F\u0430\u0432\u0448\u0438\u043C
      \u0431\u0435\u0437 \u0432\u0435\u0441\u0442\u0438. \u0412\u0441\u0435 \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0438\u0435
      \u044E\u0440\u0438\u0434\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u043F\u0440\u043E\u0446\u0435\u0434\u0443\u0440\u044B
      \u0438 \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u044B\u0435 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F
      \u043F\u043E \u0434\u0435\u043B\u0443 \u0431\u0443\u0434\u0443\u0442 \u0437\u0430\u0432\u0438\u0441\u0435\u0442\u044C
      \u043E\u0442 \u0432\u044B\u044F\u0432\u043B\u0435\u043D\u0438\u044F \u043D\u043E\u0432\u044B\u0445
      \u0434\u0430\u043D\u043D\u044B\u0445. \n\u0415\u0441\u043B\u0438 \u0443 \u0412\u0430\u0441
      \u0432\u043E\u0437\u043D\u0438\u043A\u043D\u0443\u0442 \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0435
      \u0432\u043E\u043F\u0440\u043E\u0441\u044B \u0438\u043B\u0438 \u0412\u044B
      \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u0435 \u043D\u043E\u0432\u0443\u044E
      \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044E, \u043F\u0440\u043E\u0441\u044C\u0431\u0430
      \u043D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E \u0441\u043E\u043E\u0431\u0449\u0438\u0442\u044C
      \u0432 \u0441\u043B\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
      \u043E\u0442\u0434\u0435\u043B, \u0433\u0434\u0435 \u0431\u044B\u043B \u0437\u0430\u0440\u0435\u0433\u0438\u0441\u0442\u0440\u0438\u0440\u043E\u0432\u0430\u043D
      \u0434\u0430\u043D\u043D\u044B\u0439 \u0441\u043B\u0443\u0447\u0430\u0439.
      \u0422\u0430\u043A\u0436\u0435 \u043D\u0430\u043F\u043E\u043C\u0438\u043D\u0430\u0435\u043C,
      \u0447\u0442\u043E \u0412\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u043E\u0431\u0440\u0430\u0442\u0438\u0442\u044C\u0441\u044F
      \u0432 \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0435\u0435 \u0432\u0440\u0435\u043C\u044F
      \u0434\u043B\u044F \u0443\u0442\u043E\u0447\u043D\u0435\u043D\u0438\u044F \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0438\u0445
      \u0448\u0430\u0433\u043E\u0432 \u0432 \u0432\u0430\u0448\u0435\u043C \u0434\u0435\u043B\u0435.
      \n\u041D\u0430\u0434\u0435\u0435\u043C\u0441\u044F \u043D\u0430 \u0432\u0430\u0448\u0435
      \u043F\u043E\u043D\u0438\u043C\u0430\u043D\u0438\u0435 \u0438 \u0438\u0441\u043A\u0440\u0435\u043D\u043D\u0435
      \u0432\u044B\u0440\u0430\u0436\u0430\u0435\u043C \u0441\u043E\u0431\u043E\u043B\u0435\u0437\u043D\u043E\u0432\u0430\u043D\u0438\u044F
      \u0432 \u0441\u0432\u044F\u0437\u0438 \u0441 \u0434\u0430\u043D\u043D\u043E\u0439
      \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u0435\u0439. \n\u0421 \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u0435\u043C
      (\u041F\u043E\u0434\u043F\u0438\u0441\u044C) \n\u0421\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C
      \u041B\u0430\u0442\u043D\u0438\u043A\u043E\u0432 \u0410.\u0412. \n\u0421\u043B\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435
      \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435 \u0433. \u0427\u0435\u043B\u044F\u0431\u0438\u043D\u0441\u043A\u0430
      \u0443\u043B. 45-\u043E\u0433\u043E \u0418\u043D\u0442\u0435\u0440\u043D\u0430\u0446\u0438\u043E\u043D\u0430\u043B\u0430
      51."
    m_Metadata:
      m_Items: []
  - m_Id: 10604037492736
    m_Localized: "\u041D\u0435 \u0441\u0442\u043E\u0438\u043B\u043E \u0441\u043E\u0433\u043B\u0430\u0448\u0430\u0442\u044C\u0441\u044F
      \u0441 \u044D\u0442\u0438\u043C \u0435\u0433\u043E \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435\u043C.
      \u0414\u0440\u0435\u0432\u043D\u0438\u0439 \u0423\u0440\u0430\u043B \u0441\u0442\u0430\u043B
      \u0435\u0433\u043E \u043D\u043E\u0432\u043E\u0439 \u043C\u0430\u043D\u0438\u0435\u0439,
      \u0410\u0440\u0442\u0451\u043C \u0431\u044B\u043B \u043F\u0440\u043E\u0441\u0442\u043E
      \u043E\u0434\u0435\u0440\u0436\u0438\u043C \u0438\u043C."
    m_Metadata:
      m_Items: []
  - m_Id: 11993220337664
    m_Localized: "\u0410 \u0440\u0430\u0437\u0432\u0435 \u043A\u0440\u0430\u0431\u044B
      \u0442\u0430\u043A\u043E\u0433\u043E \u0440\u0430\u0437\u043C\u0435\u0440\u0430
      \u0432\u043E\u043E\u0431\u0449\u0435 \u043E\u0431\u0438\u0442\u0430\u043B\u0438
      \u0432 \u0441\u0440\u0435\u0434\u043D\u0438\u0445 \u0448\u0438\u0440\u043E\u0442\u0430\u0445;
      \u043F\u043E\u0441\u0442\u043E\u0439, \u0442\u0443\u0442, \u043A\u0430\u0436\u0435\u0442\u0441\u044F,
      \u0435\u0441\u0442\u044C \u0437\u0430\u043F\u0438\u0441\u044C \u043E\u0431
      \u0430\u0432\u0442\u043E\u0440\u0435 \u043D\u0430\u0445\u043E\u0434\u043A\u0438
      \u0438 \u0430\u0440\u0445\u0435\u043E\u043B\u043E\u0433\u0435: \u044D\u043C\u043C\u2026
      \u0442\u0430\u043A\u2026 \u0411\u0440\u043E\u0434 \u0422\u043E\u0432\u0430\u0440\u0434?"
    m_Metadata:
      m_Items: []
  - m_Id: 12043950444544
    m_Localized: "\u041A\u0430\u0436\u0435\u0442\u0441\u044F \u0432 \u0434\u0440\u0435\u0432\u043D\u043E\u0441\u0442\u0438
      \u0431\u044B\u043B\u0438 \u043F\u043B\u0435\u043C\u0435\u043D\u0430, \u0443\u043C\u0435\u0432\u0448\u0438\u0435
      \u0434\u043E\u0431\u044B\u0432\u0430\u0442\u044C \u043F\u0430\u0443\u0442\u0438\u043D\u0443
      \u0434\u043B\u044F \u0440\u0435\u043C\u0435\u0441\u043B\u0435\u043D\u043D\u044B\u0445
      \u043D\u0443\u0436\u0434\u2026 \u041E\u043E\u043E\u0447\u0435\u043D\u044C \u043C\u043D\u043E\u0433\u043E
      \u043F\u0430\u0443\u0442\u0438\u043D\u044B\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 12056940204032
    m_Localized: "\u041F\u043E\u0433\u043E\u0434\u0438\u0442\u0435 \u043A\u0430:
      \u0430 \u0447\u0442\u043E \u043C\u043E\u043D\u0442\u0438\u0440\u043E\u0432\u043A\u0430
      \u0434\u0435\u043B\u0430\u0435\u0442 \u043D\u0430 \u0432\u0438\u0442\u0440\u0438\u043D\u0435
      \u043C\u0443\u0437\u0435\u044F \u0434\u0440\u0435\u0432\u043D\u0438\u0445 \u044D\u043F\u043E\u0445?"
    m_Metadata:
      m_Items: []
  - m_Id: 12074224930816
    m_Localized: "\u041D\u0435\u0443\u0436\u0435\u043B\u0438 \u043F\u043E\u0432\u043E\u0437\u043A\u0438
      \u0441 \u0442\u0430\u043A\u0438\u043C\u0438 \u043A\u043E\u043B\u0451\u0441\u0430\u043C\u0438
      \u0438 \u043F\u0440\u0430\u0432\u0434\u0430 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0438?
      \u042F \u0441\u043B\u044B\u0448\u0430\u043B\u0430 \u043F\u0440\u043E \u0431\u043E\u0435\u0432\u044B\u0435
      \u043A\u043E\u043B\u0435\u0441\u043D\u0438\u0446\u044B, \u043D\u043E \u043E\u043D\u0438
      \u043C\u043D\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0438\u0441\u044C
      \u0438\u043D\u0430\u0447\u0435\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 12091505463296
    m_Localized: "\u0427\u0442\u043E \u044D\u0442\u043E, \u0434\u0440\u0435\u0432\u043D\u044F\u044F
      \u043F\u0438\u0441\u044C\u043C\u0435\u043D\u043D\u043E\u0441\u0442\u044C? \u0427\u0442\u043E
      \u0437\u0434\u0435\u0441\u044C \u043D\u0430\u043F\u0438\u0441\u0430\u043D\u043E:
      \u041C\u043E\u043A \u0420\u0430? \u0417\u0430\u0433-\u0417\u0430\u0433? \u041D\u0435
      \u043C\u043E\u0433\u0443 \u0440\u0430\u0437\u043E\u0431\u0440\u0430\u0442\u044C\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 12111898169344
    m_Localized: "\u041D\u0430\u043C \u043D\u0430 \u043A\u043E\u0439-\u0442\u043E
      \u0447\u0451\u0440\u0442 \u0441\u0431\u0430\u0433\u0440\u0438\u043B\u0438 \u0441\u0442\u0430\u0440\u044B\u0435
      \u0438\u0433\u0440\u043E\u0432\u044B\u0435 \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u044B
      \u0438\u0437 \u043F\u0430\u0440\u043A\u0430 \u041F\u0443\u0448\u043A\u0438\u043D\u0430.
      \u0418\u0445 \u043F\u043E\u043A\u0430 \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0438
      \u0432 \u043F\u043E\u0434\u0432\u0430\u043B\u0435. \u041D\u0430 \u043F\u0435\u0440\u0435\u0440\u044B\u0432\u0435
      \u044F \u0440\u0435\u0448\u0438\u043B \u043F\u0440\u043E\u0442\u0435\u0441\u0442\u0438\u0442\u044C
      \u043E\u0434\u0438\u043D \u0438\u0437 \u043D\u0438\u0445: \u043E\u043D \u0434\u043E
      \u0441\u0438\u0445 \u043F\u043E\u0440 \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442!
      \u0422\u0435\u043F\u0435\u0440\u044C \u0435\u0441\u0442\u044C \u0445\u043E\u0442\u044C
      \u043A\u0430\u043A\u043E\u0435-\u0442\u043E \u0440\u0430\u0437\u0432\u043B\u0435\u043A\u0430\u043B\u043E\u0432\u043E.
      \u041F\u0440\u0430\u0432\u0434\u0430 \u044F \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E
      \u0443\u0440\u043E\u043D\u0438\u043B \u0432 \u043D\u0435\u0433\u043E \u043B\u0438\u0441\u0442\u043E\u043A,
      \u0433\u0434\u0435 \u0445\u0440\u0430\u043D\u0438\u043B \u043F\u0430\u0440\u043E\u043B\u0438
      \u0432\u0445\u043E\u0434\u0430: \u0432 \u043D\u0430\u0448\u0435\u0439 \u0421\u0411
      \u0435\u0434\u0440\u0438\u0442\u044C \u043A\u0430\u043A\u0438\u0435 \u043F\u0430\u0440\u043E\u043B\u0438
      \u0444\u0438\u0433\u0430\u0447\u0430\u0442, \u0445\u0440\u0435\u043D \u0437\u0430\u043F\u043E\u043C\u043D\u0438\u0448\u044C.
      \u041D\u0443, \u0434\u0443\u043C\u0430\u044E, \u043D\u0438\u0447\u0435\u0433\u043E
      \u043D\u0435 \u0441\u043B\u0443\u0447\u0438\u0442\u0441\u044F: \u0432\u0440\u044F\u0434
      \u043B\u0438 \u043A\u0442\u043E \u0434\u043E\u0434\u0443\u043C\u0430\u0435\u0442\u0441\u044F
      \u043B\u0435\u0437\u0442\u044C \u0437\u0430 \u043D\u0438\u043C\u0438 \u0432
      \u0430\u0432\u0442\u043E\u043C\u0430\u0442, \u0430 \u0441\u0430\u043C\u043E
      \u043E\u043D\u043E \u0438\u0445 \u0432\u044B\u043F\u043B\u044E\u043D\u0435\u0442
      \u0440\u0430\u0437\u0432\u0435 \u0447\u0442\u043E \u0432 \u0441\u043B\u0443\u0447\u0430\u0435
      \u043D\u0435\u043F\u0440\u0435\u0440\u044B\u0432\u043D\u044B\u0445 \u043F\u043E\u0431\u0435\u0434
      \u043D\u0430 \u0432\u0441\u0435\u0445 \u0443\u0440\u043E\u0432\u043D\u044F\u0445,
      \u0430 \u044F \u043C\u0430\u043D\u0430\u043B \u044D\u0442\u043E\u0442 \u0445\u0430\u0440\u0434\u043A\u043E\u0440."
    m_Metadata:
      m_Items: []
  - m_Id: 12191724163072
    m_Localized: "\u041C\u0430\u043A\u0441, \u043E\u0442 \u043B\u0438\u0446\u0430
      \u0441\u043B\u0443\u0436\u0431\u044B \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438,
      \u044F \u0441\u043D\u043E\u0432\u0430 \u0432\u044B\u0440\u0430\u0436\u0430\u044E
      \u0442\u0435\u0431\u0435 \u0438\u0441\u043A\u0440\u0435\u043D\u043D\u0435\u0435
      \u0432\u043E\u0441\u0445\u0438\u0449\u0435\u043D\u0438\u0435 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u044C\u044E
      \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C \u0435\u0434\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0439
      \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0449\u0438\u0439 \u043E\u0431\u044A\u0435\u043A\u0442
      \u0432 \u043C\u0443\u0437\u0435\u0435 \u043F\u043E\u0441\u043B\u0435 \u043F\u043E\u043B\u0443\u043D\u043E\u0447\u0438.
      \u041E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u044F\u0435\u0442,
      \u043A\u0430\u043A \u0442\u044B \u043E\u043F\u0435\u0440\u0430\u0442\u0438\u0432\u043D\u043E
      \u0440\u0435\u0430\u0433\u0438\u0440\u0443\u0435\u0448\u044C \u043D\u0430 \xAB\u0443\u0433\u0440\u043E\u0437\u044B\xBB
      \u0438\u0433\u0440\u043E\u0432\u043E\u0433\u043E \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0430
      \u0438 \u0437\u0430\u0449\u0438\u0449\u0430\u0435\u0448\u044C \u0435\u0433\u043E
      \u043E\u0442 \u043F\u044B\u043B\u0438. \n\u041E\u0434\u043D\u0430\u043A\u043E
      \u043C\u043D\u0435 \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0432\u0430\u044E\u0442
      \u043C\u043E\u043D\u0438\u0442\u043E\u0440\u044B \u0438 \u043A\u0430\u043C\u0435\u0440\u044B
      \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F \u0441 \u0436\u0430\u043B\u043E\u0431\u0430\u043C\u0438
      \u043E \u0442\u043E\u043C, \u043A\u0430\u043A \u0434\u0435\u0440\u0437\u043A\u043E
      \u0442\u044B \u0438\u0445 \u0431\u0440\u043E\u0441\u0438\u043B \u043D\u0430
      \u043F\u0440\u043E\u0438\u0437\u0432\u043E\u043B, \u043F\u0440\u043E\u043C\u0435\u043D\u044F\u0432
      \u043D\u0430 \u043A\u0430\u043A\u0443\u044E-\u0442\u043E \u0434\u0440\u0435\u0432\u043D\u044E\u044E
      \u0440\u0443\u0445\u043B\u044F\u0434\u044C. \u0414\u0443\u043C\u0430\u044E,
      \u043C\u044B \u0432\u0441\u0435 \u0441\u0447\u0438\u0442\u0430\u0435\u043C,
      \u0447\u0442\u043E 8-\u0431\u0438\u0442\u043D\u044B\u0439 \u0437\u0432\u0443\u043A
      \u2014 \u044D\u0442\u043E \u0441\u0430\u043C\u044B\u0439 \u043F\u043E\u0434\u0445\u043E\u0434\u044F\u0449\u0438\u0439
      \xAB\u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u043D\u044B\u0439 \u0444\u043E\u043D\xBB
      \u0434\u043B\u044F \u043C\u0443\u0437\u0435\u044F. \n\u041E\u0434\u043D\u0430\u043A\u043E
      \u0441\u0438\u0441\u0442\u0435\u043C\u044B \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F
      \u0440\u0435\u0432\u043D\u0443\u044E\u0442 \u0438 \u043D\u0435 \u0441\u043E\u0433\u043B\u0430\u0441\u043D\u044B
      \u043C\u0438\u0440\u0438\u0442\u044C\u0441\u044F, \u0443\u0433\u0440\u043E\u0436\u0430\u044F
      \u043F\u043E\u0434\u0430\u0442\u044C \u0432 \u0441\u0443\u0434. \u041F\u043E\u043A\u0430
      \u0447\u0442\u043E \u044F \u0441\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u044E
      \u0438\u0445 \u043D\u0430\u043F\u0430\u0434\u043A\u0438, \u043D\u043E \u043D\u0430\u0434\u043E\u043B\u0433\u043E
      \u043C\u0435\u043D\u044F \u043D\u0435 \u0445\u0432\u0430\u0442\u0438\u0442.
      \u0415\u0441\u043B\u0438 \u0442\u044B \u043D\u0435 \u0441\u043D\u0438\u0437\u0438\u0448\u044C
      \u0443\u0440\u043E\u0432\u0435\u043D\u044C \u0433\u0435\u0440\u043E\u0438\u0437\u043C\u0430
      \u0432 \u0431\u043E\u0440\u044C\u0431\u0435 \u0441 \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u043E\u043C,
      \u0431\u043E\u044E\u0441\u044C, \u043C\u044B \u043C\u043E\u0436\u0435\u043C
      \u043F\u0440\u043E\u0438\u0433\u0440\u0430\u0442\u044C \u044D\u0442\u0443 \u0431\u0438\u0442\u0432\u0443.
      \n\u0414\u0443\u043C\u0430\u044E, \u043F\u043E\u043A\u0430 \u0442\u0435\u0431\u0435
      \u0441\u0442\u043E\u0438\u0442 \u043E\u0441\u0442\u0430\u0432\u0438\u0442\u044C
      \u043F\u043E\u043F\u044B\u0442\u043A\u0438 \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
      \u043D\u043E\u0432\u044B\u0439 \u0440\u0435\u043A\u043E\u0440\u0434 \u0434\u043E
      \u043E\u043A\u043E\u043D\u0447\u0430\u043D\u0438\u044F \u0441\u043C\u0435\u043D\u044B.
      \u0412 \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u043E\u043C \u0441\u043B\u0443\u0447\u0430\u0435
      \u0430\u0432\u0442\u043E\u043C\u0430\u0442 \u0431\u0443\u0434\u0435\u0442 \u043E\u0444\u0438\u0446\u0438\u0430\u043B\u044C\u043D\u043E
      \u043F\u0440\u0438\u0437\u043D\u0430\u043D \u0441\u0430\u043C\u044B\u043C \u0434\u0438\u0441\u0446\u0438\u043F\u043B\u0438\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u043C
      \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u043E\u043C \u043C\u0435\u0441\u044F\u0446\u0430,
      \u0438 \u043C\u043D\u0435 \u043F\u0440\u0438\u0434\u0451\u0442\u0441\u044F
      \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u0442\u044C, \u043F\u043E\u0447\u0435\u043C\u0443
      \u043E\u043D \u0431\u0443\u0434\u0435\u0442 \u043F\u043E\u043B\u0443\u0447\u0430\u0442\u044C
      \u0437\u0430\u0440\u043F\u043B\u0430\u0442\u0443 \u0432\u043C\u0435\u0441\u0442\u043E
      \u0442\u0435\u0431\u044F. \n\u0421 \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u0435\u043C,
      \u0442\u0432\u043E\u0439 \u043B\u044E\u0431\u0438\u043C\u044B\u0439 \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u0438\u043A."
    m_Metadata:
      m_Items: []
  - m_Id: 12239807664128
    m_Localized: "\u0423\u0432\u0430\u0436\u0430\u0435\u043C\u044B\u0435 \u043A\u043E\u043B\u043B\u0435\u0433\u0438,
      \u0431\u043E\u043B\u044C\u0448\u0430\u044F \u043F\u0440\u043E\u0441\u044C\u0431\u0430
      \u0431\u043E\u043B\u044C\u0448\u0435 \u043D\u0435 \u043F\u0440\u043E\u043F\u0443\u0441\u043A\u0430\u0442\u044C
      \u044D\u0442\u043E\u0433\u043E \u043F\u0441\u0438\u0445\u0430 \u0432\u043D\u0443\u0442\u0440\u044C
      \u043C\u0443\u0437\u0435\u044F. \u041D\u0430 \u0434\u043D\u044F\u0445 \u043E\u043D
      \u0441\u043D\u043E\u0432\u0430 \u043A\u0440\u0438\u0447\u0430\u043B \u0447\u0442\u043E-\u0442\u043E
      \u043F\u0440\u043E \u0434\u0432\u0435\u0440\u0438 \u0432 \u043F\u0440\u043E\u0448\u043B\u043E\u0435
      \u0438 \u043F\u0440\u043E \u0432\u044B\u0441\u0448\u0443\u044E \u0440\u0430\u0441\u0443,
      \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0437\u0430 \u0437\u0430\u0432\u0435\u0441\u043E\u0439
      \u0432\u0440\u0435\u043C\u0435\u043D\u0438 \u0441\u043B\u0435\u0434\u0438\u0442
      \u0437\u0430 \u043D\u0430\u043C\u0438. \u041C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C,
      \u044F \u043D\u0435 \u042D\u0439\u043D\u0448\u0442\u0435\u0439\u043D, \u043D\u0430\u043C
      \u044D\u0442\u043E \u0432\u0441\u0451 \u043D\u0430\u0444\u0438\u0433 \u043D\u0435
      \u043D\u0443\u0436\u043D\u043E. \n\u0418 \u0433\u043B\u0430\u0432\u043D\u043E\u0435
      \u2014 \u044D\u0442\u043E\u0442 \u0442\u0438\u043F \u0432\u0441\u0451 \u0432\u0440\u0435\u043C\u044F
      \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u0435\u0442 \u043A\u0440\u0430\u043D\u044B
      \u0432 \u0442\u0443\u0430\u043B\u0435\u0442\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u044B\u043C\u0438,
      \u043A\u0430\u043A \u0431\u0443\u0434\u0442\u043E \u0432\u043C\u0435\u0441\u0442\u043E
      \u0431\u0443\u043C\u0430\u0433\u0438 \u043C\u044B \u0442\u0443\u0434\u0430
      \u043A\u0443\u043F\u044E\u0440\u044B \u043D\u0430\u0432\u0430\u043B\u0438\u0432\u0430\u0435\u043C.
      \u0415\u0441\u043B\u0438 \u0436\u0435 \u043F\u0440\u043E\u043C\u043E\u0440\u0433\u0430\u043B\u0438,
      \u0442\u043E \u0435\u0433\u043E \u043C\u043E\u0436\u043D\u043E \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C
      \u043F\u043E \u043F\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044E: \u043E\u043D
      \u0448\u0430\u0440\u0430\u0445\u0430\u0435\u0442\u0441\u044F \u043F\u043E \u0431\u043E\u043B\u044C\u0448\u043E\u043C\u0443
      \u0437\u0430\u043B\u0443 \u043A\u0430\u043A \u043F\u043E\u043B\u043E\u0443\u043C\u043D\u044B\u0439,
      \u0447\u0442\u043E-\u0442\u043E \u0448\u0435\u043F\u0447\u0435\u0442 \u0441\u0435\u0431\u0435
      \u043F\u043E\u0434 \u043D\u043E\u0441, \u0438\u043D\u043E\u0433\u0434\u0430
      \u043F\u043E\u0434\u0431\u0438\u0440\u0430\u0435\u0442 \u0447\u0442\u043E-\u0442\u043E
      \u0438\u0437 \u0443\u0440\u043D\u044B, \u0438 \u0431\u0440\u043E\u0441\u0430\u0435\u0442
      \u043E\u0431\u0440\u0430\u0442\u043D\u043E. \n\u0418 \u0434\u0430, \u0440\u0430\u0434\u0438
      \u0432\u0441\u0435\u0445 \u0431\u043E\u0433\u043E\u0432, \u043D\u0435 \u043E\u0431\u0441\u0443\u0436\u0434\u0430\u0439\u0442\u0435
      \u0441 \u043D\u0438\u043C \u0435\u0433\u043E \u0442\u0435\u043E\u0440\u0438\u0438
      \u043A\u043E\u043D\u0446\u0430 \u0438 \u043D\u0430\u0447\u0430\u043B\u0430
      \u0441\u0432\u0435\u0442\u0430. \u041E\u0442\u0432\u0435\u0434\u0438\u0442\u0435
      \u0435\u0433\u043E \u0432 \u043C\u043E\u0439 \u043A\u0430\u0431\u0438\u043D\u0435\u0442
      \u0438\u043B\u0438 \u0441\u0440\u0430\u0437\u0443 \u043D\u0430 \u0443\u043B\u0438\u0446\u0443,
      \u0435\u0441\u043B\u0438 \u0431\u0443\u0434\u0435\u0442 \u0441\u043E\u043F\u0440\u043E\u0442\u0438\u0432\u043B\u044F\u0442\u044C\u0441\u044F.
      \u0421\u043C\u0435\u0448\u043D\u043E \u0431\u044B\u043B\u043E \u043B\u0438\u0448\u044C
      \u043F\u0435\u0440\u0432\u044B\u0435 513 \u0440\u0430\u0437, \u0430 \u0441\u0435\u0439\u0447\u0430\u0441
      \u043E\u043D \u0443\u0436\u0435 \u0432\u0441\u0435\u0445 \u0437\u0430\u0434\u043E\u043B\u0431\u0430\u043B.
      \u0425\u043E\u0440\u043E\u0448\u043E \u043E\u043D \u0445\u043E\u0442\u044C
      \u0437\u0430\u0445\u043E\u0434\u0438\u0442 \u043D\u0435 \u0447\u0430\u0441\u0442\u043E,
      \u043E\u0431\u044B\u0447\u043D\u043E \u043F\u043E \u0432\u0442\u043E\u0440\u043D\u0438\u043A\u0430\u043C
      \u0438 \u043F\u044F\u0442\u043D\u0438\u0446\u0430\u043C, \u0430 \u0442\u043E
      \u043D\u0430\u0448\u0443 \u0432\u044B\u0432\u0435\u0441\u043A\u0443 \u0441\u043A\u043E\u0440\u043E
      \u0443\u0436\u0435 \u043D\u0430\u0447\u0430\u043B\u0438 \u0431\u044B \u043F\u0443\u0442\u0430\u0442\u044C
      \u0441 \u0434\u0443\u0440\u043A\u043E\u0439 \u0441 \u0442\u0430\u043A\u0438\u043C\u0438
      \u043A\u043E\u043B\u043B\u0430\u0431\u043E\u0440\u0430\u0446\u0438\u044F\u043C\u0438.
      \n\u041F\u043E \u043F\u043E\u0432\u043E\u0434\u0443 \u0432\u043E\u0434\u044B
      \u2014 \u0437\u0430\u0433\u043B\u044F\u0434\u044B\u0432\u0430\u0439\u0442\u0435
      \u043A\u0430\u0436\u0434\u044B\u0435 \u0434\u0432\u0430 \u0447\u0430\u0441\u0430
      \u0432 \u0442\u0443\u0430\u043B\u0435\u0442: \u044D\u0442\u043E\u0442 \u0447\u0451\u0440\u0442\u043E\u0432
      \u043D\u0438\u043D\u0434\u0437\u044F \u0438\u043D\u043E\u0433\u0434\u0430 \u0441\u043B\u043E\u0432\u043D\u043E
      \u0437\u043D\u0430\u0435\u0442 \u0432\u0441\u0435 \u0441\u043B\u0435\u043F\u044B\u0435
      \u0437\u043E\u043D\u044B \u043A\u0430\u043C\u0435\u0440 \u043D\u0430\u0431\u043B\u044E\u0434\u0435\u043D\u0438\u044F!
      \nP.S. \u0424\u0430\u043D\u0442\u0430\u0441\u0442\u0438\u043A\u0430 \u2014
      \u043D\u0435 \u043F\u043E\u0432\u043E\u0434 \u043D\u0435 \u0432\u044B\u043A\u043B\u044E\u0447\u0430\u0442\u044C
      \u043A\u0440\u0430\u043D\u044B! \n\u0421 \u0443\u0432\u0430\u0436\u0435\u043D\u0438\u0435\u043C,
      \u041D\u0430\u0447\u0430\u043B\u044C\u043D\u0438\u043A \u0441\u043B\u0443\u0436\u0431\u044B
      \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438."
    m_Metadata:
      m_Items: []
  - m_Id: 12255209148416
    m_Localized: "\u0425\u043C, \u043A\u0430\u0436\u0435\u0442\u0441\u044F, \u044D\u0442\u043E
      \u043C\u043E\u0436\u0435\u0442 \u043F\u0440\u0438\u0433\u043E\u0434\u0438\u0442\u044C\u0441\u044F."
    m_Metadata:
      m_Items: []
  - m_Id: 12279972319232
    m_Localized: "\u041A\u0430\u0436\u0435\u0442\u0441\u044F, \u0442\u0443\u0442
      \u043D\u0438\u0447\u0435\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E\u0433\u043E."
    m_Metadata:
      m_Items: []
  - m_Id: 12370065969152
    m_Localized: "\u042D\u0442\u043E\u0442 \u043F\u0441\u0438\u0445 \u0447\u0442\u043E-\u0442\u043E
      \u043A\u0440\u0438\u0447\u0430\u043B \u043F\u0440\u043E \u0434\u0432\u0435\u0440\u0438
      \u0432 \u043F\u0440\u043E\u0448\u043B\u043E\u0435, \u0438 \u0447\u0442\u043E
      \u0432\u044B\u0441\u0448\u0430\u044F \u0440\u0430\u0441\u0430 \u0437\u0430
      \u0437\u0430\u0432\u0435\u0441\u043E\u0439 \u0432\u0440\u0435\u043C\u0435\u043D\u0438
      \u0441\u043B\u0435\u0434\u0438\u0442 \u0437\u0430 \u043D\u0430\u043C\u0438,
      \u043C\u044B \u043C\u043E\u0436\u0435\u043C \u0431\u044B\u0442\u044C \u0432
      \u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438. \u0422\u044C\u0444\u0443,
      \u044D\u0442\u0438 \u0448\u0438\u0437\u0438\u043A\u0438 \u0441\u043E\u0432\u0441\u0435\u043C
      \u0440\u0435\u0445\u043D\u0443\u043B\u0438\u0441\u044C \u0443\u0436\u0435 \u043D\u0430
      \u0441\u0432\u043E\u0435\u0439 \u0444\u0430\u043D\u0442\u0430\u0441\u0442\u0438\u043A\u0435;
      \u0430 \u0435\u0449\u0451 \u043E\u043D \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E
      \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u043B \u0432\u0441\u0435 \u043A\u0440\u0430\u043D\u044B
      \u0432 \u0442\u0443\u0430\u043B\u0435\u0442\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u044B\u043C\u0438
      \u0438 \u0448\u0430\u0440\u0430\u0445\u0430\u043B\u0441\u044F \u0433\u0434\u0435-\u0442\u043E
      \u043F\u043E \u0432\u0442\u043E\u0440\u043E\u043C\u0443 \u0437\u0430\u043B\u0443,
      \u0431\u0443\u0434\u0442\u043E \u0443 \u043D\u0430\u0441 \u0431\u044E\u0434\u0436\u0435\u0442
      \u0440\u0435\u0437\u0438\u043D\u043E\u0432\u044B\u0439 \u0441\u0447\u0435\u0442\u0430
      \u043D\u0430 \u0432\u043E\u0434\u0443 \u0432 \u0434\u0432\u0435 \u0437\u0430\u0440\u043F\u043B\u0430\u0442\u044B
      \u0432\u044B\u043A\u0438\u0434\u044B\u0432\u0430\u0442\u044C."
    m_Metadata:
      m_Items: []
  - m_Id: 12382917316608
    m_Localized: "\u041F\u043E\u043C\u043D\u044E, \u043A\u043E\u0433\u0434\u0430
      \u0410\u0440\u0442\u0451\u043C \u0433\u043B\u0443\u0431\u043E\u043A\u043E \u0437\u0430\u0434\u0443\u043C\u044B\u0432\u0430\u043B\u0441\u044F,
      \u0442\u043E \u0447\u0430\u0441\u0442\u043E \u043A\u0440\u0443\u0442\u0438\u043B
      \u0435\u0451 \u0432 \u0440\u0443\u043A\u0435, \u043A\u0430\u043A \u043F\u0440\u043E\u043F\u0435\u043B\u043B\u0435\u0440.
      \u041A\u0430\u043A-\u0442\u043E \u043E\u043D \u0437\u0430\u043C\u0435\u0442\u0438\u043B,
      \u0447\u0442\u043E \u0443 \u044D\u0442\u043E\u0439 \u0440\u0443\u0447\u043A\u0438
      \u0443\u0434\u0438\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439 \u0431\u0430\u043B\u0430\u043D\u0441."
    m_Metadata:
      m_Items: []
  - m_Id: 12396074848256
    m_Localized: "\u0410\u0440\u0442\u0451\u043C \u0447\u0430\u0441\u0442\u043E \u043D\u043E\u0441\u0438\u043B
